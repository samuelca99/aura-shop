---
const token = import.meta.env.AIRTABLE_TOKEN;
const baseId = import.meta.env.AIRTABLE_BASE_ID;
const tableName = import.meta.env.AIRTABLE_TABLE_NAME;

// NO OLVIDES PONER TU NÚMERO AQUÍ
const miTelefono = "59178706782"; 

const response = await fetch(`https://api.airtable.com/v0/${baseId}/${tableName}`, {
  headers: { Authorization: `Bearer ${token}` }
});

const data = await response.json();
const productos = data.records || [];
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Aura Shop | Catálogo</title>
  <style>
    :root { --primary: #000000; --accent: #25D366; --bg: #f8fafc; }
    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; background: var(--bg); color: #333; }
    
    /* --- Cabecera y Buscador Moderno --- */
    .main-header { 
      display: flex; 
      flex-direction: column; 
      align-items: center; 
      padding: 2rem 1rem 1.5rem 1rem; 
      margin-bottom: 0.5rem; /* Reduje el margen para acercar las categorías */
    }
    
    .logo-container { 
      margin-bottom: 1.5rem; 
    }
    
    .logo-img { 
      height: 300px; 
      width: auto; 
      object-fit: contain; 
    }
    
    .search-container { 
      width: 100%; 
      max-width: 600px; 
    }
    
    .search-input { 
      width: 100%; 
      padding: 15px 20px; 
      font-size: 1.1rem; 
      color: #333; 
      border: 2px solid #e2e8f0; 
      border-radius: 30px; 
      outline: none; 
      background-color: white; 
      box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); 
      transition: all 0.3s ease; 
      box-sizing: border-box; 
    }
    
    .search-input:focus { 
      border-color: var(--primary); 
      box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); 
    }

    /* --- NUEVO: Categorías (Pills) --- */
    .categories-wrapper { 
      width: 100%; 
      max-width: 1200px; 
      margin: 0 auto 2rem auto; 
      padding: 0 1rem; 
      box-sizing: border-box; 
    }
    
    .categories-container { 
      display: flex; 
      gap: 10px; 
      overflow-x: auto; 
      padding-bottom: 10px; 
      scrollbar-width: none; /* Oculta barra en Firefox */ 
    }
    
    .categories-container::-webkit-scrollbar { 
      display: none; /* Oculta barra en Chrome/Safari */ 
    }
    
    .category-pill { 
      padding: 8px 20px; 
      border: 1px solid #e2e8f0; 
      background-color: white; 
      border-radius: 50px; 
      font-size: 0.95rem; 
      font-weight: 600; 
      color: #64748b; 
      cursor: pointer; 
      white-space: nowrap; 
      transition: all 0.3s ease; 
    }
    
    .category-pill:hover { 
      border-color: var(--primary); 
      color: var(--primary); 
    }
    
    .category-pill.active { 
      background-color: var(--primary); 
      color: white; 
      border-color: var(--primary); 
    }

    /* --- Grilla de Productos --- */
    .container { max-width: 1200px; margin: 0 auto 4rem; padding: 0 1rem; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2rem; }
    .card { background: white; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); transition: transform 0.2s; display: flex; flex-direction: column; }
    .card:hover { transform: translateY(-5px); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }
    .card img { width: 100%; height: 280px; object-fit: cover; }
    
    /* --- Info de la Tarjeta --- */
    .info { padding: 1.5rem; flex-grow: 1; display: flex; flex-direction: column; }
    .title { font-size: 1.2rem; font-weight: 700; margin: 0 0 0.5rem 0; text-transform: capitalize; }
    .price { font-size: 1.4rem; color: var(--accent); font-weight: 900; margin: 0 0 1rem 0; }
    .desc { font-size: 0.9rem; color: #64748b; line-height: 1.4; margin-bottom: 1rem; }
    .tallas { font-size: 0.85rem; color: #64748b; margin-bottom: 1.5rem; background: #f1f5f9; padding: 5px 10px; border-radius: 8px; display: inline-block; }
    
    /* --- Botones y Mensajes --- */
    .btn-ws { background: var(--primary); color: white; text-align: center; padding: 12px; border-radius: 10px; text-decoration: none; font-weight: bold; transition: background 0.3s; margin-top: auto; }
    .btn-ws:hover { background: var(--accent); }
    .sin-resultados { text-align: center; grid-column: 1 / -1; color: #64748b; display: none; padding: 3rem; font-size: 1.2rem; }
  </style>
</head>
<body>

  <header class="main-header">
    <div class="logo-container">
      <img src="https://i.postimg.cc/nrQkYZ0m/logo.png" alt="Logo Aura Shop" class="logo-img" />
    </div>
    <div class="search-container">
      <input type="text" id="buscador" class="search-input" placeholder="🔍 Buscar perfumes, ropa, marcas..." />
    </div>
  </header>

  <div class="categories-wrapper">
    <div class="categories-container" id="contenedor-categorias">
      <button class="category-pill active" data-categoria="todos">Todos</button>
      <button class="category-pill" data-categoria="zapatillas">Zapatillas</button>
      <button class="category-pill" data-categoria="perfumes">Perfumes</button>
      <button class="category-pill" data-categoria="ropa">Ropa</button>
      <button class="category-pill" data-categoria="accesorios">Accesorios</button>
    </div>
  </div>

  <main class="container">
    <div class="grid" id="contenedor-productos">
      {productos.map((prod) => {
        const fields = prod.fields;
        const nombre = fields["Nombre del producto"] || "";
        const precio = fields["Precio en bolivianos"] || "Consultar";
        const tallas = fields["Tallas"] || "Única";
        const descripcion = fields["Descripción"] || "";
        const img = fields["Imágenes"] || "https://via.placeholder.com/400?text=Aura+Shop"; 
        
        // AQUÍ LEEMOS LA COLUMNA CATEGORÍA DE TU AIRTABLE
        const categoria = fields["Categoría"] || "otros";

        const texto = `Hola Aura Shop! Me interesa:\n- *${nombre}*\n- Talla: ${tallas}\n- Precio: Bs. ${precio}\n¿Tienen stock?`;
        const linkWS = `https://wa.me/${miTelefono}?text=${encodeURIComponent(texto)}`;

        return (
          // AÑADIMOS data-categoria PARA QUE EL JS LO PUEDA FILTRAR
          <div class="card producto-card" data-nombre={nombre.toLowerCase()} data-categoria={categoria.toLowerCase()}>
            <img src={img} alt={nombre} loading="lazy" />
            <div class="info">
              <h2 class="title">{nombre}</h2>
              <p class="price">Bs. {precio}</p>
              <p class="desc">{descripcion}</p>
              <div><span class="tallas">Tallas: {tallas}</span></div>
              <a href={linkWS} target="_blank" class="btn-ws">Comprar por WhatsApp</a>
            </div>
          </div>
        );
      })}
      
      <div id="mensaje-vacio" class="sin-resultados">
        No encontramos ningún producto con esos filtros 😔
      </div>
    </div>
  </main>

  <script>
    const inputBuscador = document.getElementById('buscador');
    const botonesCategoria = document.querySelectorAll('.category-pill');
    const tarjetas = document.querySelectorAll('.producto-card');
    const mensajeVacio = document.getElementById('mensaje-vacio');

    let textoBusquedaActual = "";
    let categoriaActivaActual = "todos";

    function filtrarProductos() {
      let visibles = 0;

      tarjetas.forEach(tarjeta => {
        const nombreProducto = tarjeta.getAttribute('data-nombre');
        const categoriaProducto = tarjeta.getAttribute('data-categoria');
        
        const coincideTexto = nombreProducto.includes(textoBusquedaActual);
        const coincideCategoria = (categoriaActivaActual === "todos") || (categoriaProducto === categoriaActivaActual);

        if (coincideTexto && coincideCategoria) {
          tarjeta.style.display = 'flex'; 
          visibles++;
        } else {
          tarjeta.style.display = 'none'; 
        }
      });

      mensajeVacio.style.display = visibles === 0 ? 'block' : 'none';
    }

    // Buscador
    inputBuscador.addEventListener('input', (evento) => {
      textoBusquedaActual = evento.target.value.toLowerCase();
      filtrarProductos();
    });

    // Botones de Categoría
    botonesCategoria.forEach(boton => {
      boton.addEventListener('click', (evento) => {
        botonesCategoria.forEach(b => b.classList.remove('active'));
        evento.target.classList.add('active');
        
        categoriaActivaActual = evento.target.getAttribute('data-categoria');
        filtrarProductos();
      });
    });
  </script>
</body>
</html>