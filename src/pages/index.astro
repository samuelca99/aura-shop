---
const token = import.meta.env.AIRTABLE_TOKEN;
const baseId = import.meta.env.AIRTABLE_BASE_ID;
const tableName = import.meta.env.AIRTABLE_TABLE_NAME;

const miTelefono = "59178706782"; 

const response = await fetch(`https://api.airtable.com/v0/${baseId}/${tableName}`, {
  headers: { Authorization: `Bearer ${token}` }
});

const data = await response.json();
const productos = data.records || [];

const categoriasUnicas = [...new Set(productos.map(p => p.fields["Categoría"] || "Otros"))].sort();
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Aura Shop | Catálogo</title>
  <style>
    :root { --primary: #000000; --accent: #25D366; --bg: #f8fafc; }
    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; background: var(--bg); color: #333; }
    
    /* --- CABECERA --- */
    .main-header { display: flex; flex-direction: column; align-items: center; padding: 2rem 1rem 1.5rem 1rem; margin-bottom: 0; }
    .logo-container { margin-bottom: 1.5rem; }
    .logo-img { height: 300px; width: auto; object-fit: contain; }
    .search-container { width: 100%; max-width: 600px; }
    .search-input { width: 100%; padding: 15px 20px; font-size: 1.1rem; color: #333; border: 2px solid #e2e8f0; border-radius: 30px; outline: none; background-color: white; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); transition: all 0.3s ease; box-sizing: border-box; }
    .search-input:focus { border-color: var(--primary); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }

    /* --- BANNER ANIMADO --- */
    .promo-banner { background-color: var(--primary); color: white; padding: 10px 0; overflow: hidden; white-space: nowrap; margin-bottom: 2rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
    .promo-content { display: inline-block; animation: scrollBanner 25s linear infinite; }
    .promo-content:hover { animation-play-state: paused; }
    .promo-item { display: inline-block; margin: 0 40px; font-size: 0.95rem; font-weight: 600; letter-spacing: 0.5px; }
    @keyframes scrollBanner { 0% { transform: translateX(10%); } 100% { transform: translateX(-100%); } }

    /* --- CATEGORÍAS --- */
    .categories-wrapper { width: 100%; max-width: 1200px; margin: 0 auto 2rem auto; padding: 0 1rem; box-sizing: border-box; }
    .categories-container { display: flex; gap: 10px; overflow-x: auto; padding-bottom: 10px; scrollbar-width: none; }
    .categories-container::-webkit-scrollbar { display: none; }
    .category-pill { padding: 8px 20px; border: 1px solid #e2e8f0; background-color: white; border-radius: 50px; font-size: 0.95rem; font-weight: 600; color: #64748b; cursor: pointer; white-space: nowrap; transition: all 0.3s ease; text-transform: capitalize; }
    .category-pill:hover { border-color: var(--primary); color: var(--primary); }
    .category-pill.active { background-color: var(--primary); color: white; border-color: var(--primary); }

    /* --- GRILLA Y TARJETAS --- */
    .container { max-width: 1200px; margin: 0 auto 4rem; padding: 0 1rem; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2rem; }
    .card { background: white; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); transition: transform 0.2s; display: flex; flex-direction: column; position: relative; }
    .card:hover { transform: translateY(-5px); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }
    
    /* --- CARRUSEL DE IMÁGENES (REFORZADO) --- */
    .carousel { position: relative; width: 100%; height: 320px; overflow: hidden; background: #eee; }
    .slide { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 0.4s ease-in-out; z-index: 1; }
    .slide.active { opacity: 1; z-index: 2; }
    .carousel-btn { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.8); border: none; border-radius: 50%; width: 40px; height: 40px; cursor: pointer; z-index: 10; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: bold; transition: 0.3s; }
    .carousel-btn:hover { background: white; scale: 1.1; }
    .prev { left: 10px; }
    .next { right: 10px; }

    /* Puntos indicadores */
    .dots-container { position: absolute; bottom: 10px; width: 100%; display: flex; justify-content: center; gap: 5px; z-index: 15; }
    .dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.5); transition: 0.3s; }
    .dot.active { background: white; width: 20px; border-radius: 4px; }

    /* --- INFO DEL PRODUCTO --- */
    .info { padding: 1.5rem; flex-grow: 1; display: flex; flex-direction: column; }
    .title { font-size: 1.2rem; font-weight: 700; margin: 0 0 0.5rem 0; text-transform: capitalize; }
    .price { font-size: 1.4rem; color: var(--accent); font-weight: 900; margin: 0 0 1rem 0; }
    .desc { font-size: 0.9rem; color: #64748b; line-height: 1.4; margin-bottom: 1rem; }
    .tallas { font-size: 0.85rem; color: #64748b; margin-bottom: 1.5rem; background: #f1f5f9; padding: 5px 10px; border-radius: 8px; display: inline-block; }
    
    .btn-ws { background: var(--primary); color: white; text-align: center; padding: 12px; border-radius: 10px; text-decoration: none; font-weight: bold; transition: background 0.3s; margin-top: auto; }
    .btn-ws:hover { background: var(--accent); }
    .sin-resultados { text-align: center; grid-column: 1 / -1; color: #64748b; display: none; padding: 3rem; font-size: 1.2rem; }

    /* --- FOOTER --- */
    .site-footer { background-color: #0f172a; color: #f8fafc; padding: 4rem 1rem 2rem 1rem; margin-top: 4rem; }
    .footer-container { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 3rem; }
    .footer-col h3 { color: white; font-size: 1.3rem; margin-bottom: 1.5rem; letter-spacing: 1px; }
    .footer-col p { color: #94a3b8; font-size: 0.95rem; line-height: 1.6; margin-bottom: 1rem; }
    .social-links { display: flex; flex-direction: column; gap: 12px; }
    .social-links a { color: #94a3b8; text-decoration: none; display: flex; align-items: center; font-size: 1rem; transition: color 0.3s, transform 0.3s; }
    .social-links a:hover { color: white; transform: translateX(5px); }
    .map-container { width: 100%; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.3); height: 220px; }
    .map-container iframe { width: 100%; height: 100%; border: none; }
    .footer-bottom { text-align: center; margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid #1e293b; color: #64748b; font-size: 0.85rem; }
  </style>
</head>
<body>

  <header class="main-header">
    <div class="logo-container">
      <img src="https://i.postimg.cc/nrQkYZ0m/logo.png" alt="Logo Aura Shop" class="logo-img" />
    </div>
    <div class="search-container">
      <input type="text" id="buscador" class="search-input" placeholder="🔍 Buscar perfumes, ropa, marcas..." />
    </div>
  </header>

  <div class="promo-banner">
    <div class="promo-content">
      <span class="promo-item">🚚 Entregas seguras en todo Tarija</span>
      <span class="promo-item">🏬 Retiro en nuestra Tienda Física</span>
      <span class="promo-item">✨ Garantía de autenticidad en cada producto</span>
      <span class="promo-item">💳 Aceptamos Pagos por QR y Transferencia</span>
    </div>
  </div>

  <div class="categories-wrapper">
    <div class="categories-container" id="contenedor-categorias">
      <button class="category-pill active" data-categoria="todos">Todos</button>
      {categoriasUnicas.map((cat) => (
        <button class="category-pill" data-categoria={cat.toLowerCase()}>{cat}</button>
      ))}
    </div>
  </div>

  <main class="container">
    <div class="grid" id="contenedor-productos">
      {productos.map((prod) => {
        const fields = prod.fields;
        const nombre = fields["Nombre del producto"] || "";
        const precio = fields["Precio en bolivianos"] || "Consultar";
        const tallas = fields["Tallas"] || "Única";
        const descripcion = fields["Descripción"] || "";
        const categoria = fields["Categoría"] || "otros";
        
        // Separamos los links por la coma
        const imgField = fields["Imágenes"] || "https://via.placeholder.com/400?text=Aura+Shop";
        const imagenesArray = imgField.split(',').map(url => url.trim());

        const texto = `Hola Aura Shop! Me interesa:\n- *${nombre}*\n- Talla: ${tallas}\n- Precio: Bs. ${precio}\n¿Tienen stock?`;
        const linkWS = `https://wa.me/${miTelefono}?text=${encodeURIComponent(texto)}`;

        return (
          <div class="card producto-card" data-nombre={nombre.toLowerCase()} data-categoria={categoria.toLowerCase()}>
            
            <div class="carousel">
              {imagenesArray.map((url, index) => (
                <img src={url} alt={nombre} loading="lazy" class={index === 0 ? "slide active" : "slide"} />
              ))}
              
              {imagenesArray.length > 1 && (
                <>
                  <button class="carousel-btn prev" aria-label="Anterior">‹</button>
                  <button class="carousel-btn next" aria-label="Siguiente">›</button>
                  <div class="dots-container">
                    {imagenesArray.map((_, i) => (
                      <div class={i === 0 ? "dot active" : "dot"}></div>
                    ))}
                  </div>
                </>
              )}
            </div>

            <div class="info">
              <h2 class="title">{nombre}</h2>
              <p class="price">Bs. {precio}</p>
              <p class="desc">{descripcion}</p>
              <div><span class="tallas">Tallas: {tallas}</span></div>
              <a href={linkWS} target="_blank" class="btn-ws">Comprar por WhatsApp</a>
            </div>
          </div>
        );
      })}
      
      <div id="mensaje-vacio" class="sin-resultados">
        No encontramos ningún producto con esos filtros 😔
      </div>
    </div>
  </main>

  <footer class="site-footer">
    <div class="footer-container">
      
      <div class="footer-col">
        <h3>Logística y Confianza</h3>
        <p>En Aura Shop manejamos un modelo ágil de <strong>Tienda Fisica + Delivery</strong>. Aseguramos que tus prendas y fragancias de alto rendimiento lleguen a tus manos de forma rápida y segura.</p>
        <p>Aceptamos pagos en efectivo contra entrega y transferencias mediante código QR.</p>
      </div>

      <div class="footer-col">
        <h3>Nuestras Redes</h3>
        <div class="social-links">
          <a href={`https://wa.me/${miTelefono}`} target="_blank">🟢 WhatsApp: 78706782</a>
          <a href="https://www.instagram.com/aura.shop.bolivia/" target="_blank">🟣 Instagram: @AuraShop</a>
          <a href="https://www.tiktok.com/@aura_shop_bol" target="_blank">⚫ TikTok: @aura.shop.bolivia</a>
          <a href="https://www.facebook.com/profile.php?id=61574306677803" target="_blank">🔵 Facebook: @aura.shop.bolivia</a>
        </div>
      </div>

      <div class="footer-col">
        <h3>Ubicación</h3>
        <p>📍 Tarija, Bolivia<br>Calle Ingavi entre Mendez y Santa Cruz<br>Centro Comercial Guadalquivir caseta 31</p>
        <div class="map-container">
          <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d118228.31826079093!2d-64.79373976326622!3d-21.5360341738596!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94064be2b322f28b%3A0x9ff8e7b92bdcc68e!2sTarija%2C%20Bolivia!5e0!3m2!1ses!2s!4v1700000000000!5m2!1ses!2s2" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>
      
    </div>
    
    <div class="footer-bottom">
      © 2026 Aura Shop. Todos los derechos reservados. | Desarrollado a medida.
    </div>
  </footer>

  <script>
    // 1. Filtrado (Buscador + Categorías)
    const buscador = document.getElementById('buscador');
    const pills = document.querySelectorAll('.category-pill');
    const cards = document.querySelectorAll('.producto-card');
    const mensajeVacio = document.getElementById('mensaje-vacio');

    function filtrar() {
      const txt = buscador.value.toLowerCase();
      // Verificamos si hay un botón activo antes de buscarlo (para evitar errores si no hay categorías)
      const botonActivo = document.querySelector('.category-pill.active');
      const activeCat = botonActivo ? botonActivo.dataset.categoria : 'todos';
      let visibles = 0;
      
      cards.forEach(c => {
        const matchTxt = c.dataset.nombre.includes(txt);
        const matchCat = activeCat === 'todos' || c.dataset.categoria === activeCat;
        if (matchTxt && matchCat) {
          c.style.display = 'flex';
          visibles++;
        } else {
          c.style.display = 'none';
        }
      });
      mensajeVacio.style.display = visibles === 0 ? 'block' : 'none';
    }

    buscador.addEventListener('input', filtrar);
    pills.forEach(p => {
      p.addEventListener('click', () => {
        pills.forEach(x => x.classList.remove('active'));
        p.classList.add('active');
        filtrar();
      });
    });

    // 2. Lógica del Carrusel REFORZADA (La que te faltaba copiar)
    document.querySelectorAll('.carousel').forEach(car => {
      const slides = car.querySelectorAll('.slide');
      const dots = car.querySelectorAll('.dot');
      const btnNext = car.querySelector('.next');
      const btnPrev = car.querySelector('.prev');
      let idx = 0;

      if (!btnNext) return; // Si solo hay 1 imagen, no ejecuta esto

      function update() {
        slides.forEach((s, i) => {
          s.classList.remove('active');
          if(dots[i]) dots[i].classList.remove('active');
        });
        slides[idx].classList.add('active');
        if(dots[idx]) dots[idx].classList.add('active');
      }

      btnNext.addEventListener('click', (e) => {
        e.stopPropagation(); // Evita clics fantasma
        idx = (idx + 1) % slides.length;
        update();
      });

      btnPrev.addEventListener('click', (e) => {
        e.stopPropagation();
        idx = (idx - 1 + slides.length) % slides.length;
        update();
      });
    });
  </script>
</body>
</html>